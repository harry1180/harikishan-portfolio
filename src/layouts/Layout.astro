---
const {
	title = 'Hari Kishan | Resume',
	description = 'A modern resume website for an enterprise technology, cloud, data, and AI leader.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
		background: #f6f3ed;
		color: #202124;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
	}

	* {
		box-sizing: border-box;
	}

	a {
		color: inherit;
	}

	::selection {
		background: #234c46;
		color: #fffaf1;
	}
</style>
